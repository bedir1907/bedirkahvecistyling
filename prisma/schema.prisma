generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  CREATOR
  MANAGER
  SALES
}

model Product {
  id           Int      @id @default(autoincrement())
  productCode  String   @unique
  name         String
  slug         String   @unique

  color        String?
  groupCode    String?

  price        Int
  oldPrice     Int?
  image        String
  category     String
  description  String

  sizes        String[]
  colors       String[]
  stock        Int

  featured     Boolean  @default(false)
  isNew        Boolean  @default(false)
  isActive     Boolean  @default(true)
  displayOrder Int      @default(0)

  images          ProductImage[]
  colorGroups     ProductColorGroup[]
  productVariants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([groupCode])
  @@index([category])
  @@index([isActive])
}

model ProductImage {
  id        Int     @id @default(autoincrement())
  productId Int
  url       String
  alt       String?
  color     String?
  sortOrder Int     @default(0)
  isCover   Boolean @default(false)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
}

model ProductColorGroup {
  id                Int     @id @default(autoincrement())
  productId         Int
  colorName         String
  sizeType          String  @default("letter")
  sortOrder         Int     @default(0)
  isActive          Boolean @default(true)
  showAsProductCard Boolean @default(false)
  productCardName   String?

  product  Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  images   ProductColorImage[]
  variants ProductVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, colorName])
}

model ProductColorImage {
  id           Int     @id @default(autoincrement())
  colorGroupId Int
  url          String
  alt          String?
  sortOrder    Int     @default(0)
  isCover      Boolean @default(false)

  colorGroup ProductColorGroup @relation(fields: [colorGroupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductVariant {
  id           Int     @id @default(autoincrement())
  colorGroupId Int?
  size         String
  stock        Int     @default(0)
  sku          String?

  productId    Int?

  colorGroup ProductColorGroup? @relation(fields: [colorGroupId], references: [id], onDelete: Cascade)
  product    Product?           @relation(fields: [productId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([colorGroupId])
}

model Category {
  id           Int     @id @default(autoincrement())
  name         String  @unique
  slug         String  @unique
  image        String?
  isFeatured   Boolean @default(false)
  isActive     Boolean @default(true)
  displayOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AdminUser {
  id           Int       @id @default(autoincrement())
  name         String
  email        String    @unique
  passwordHash String
  role         AdminRole @default(SALES)
  isActive     Boolean   @default(true)

  canManageProducts    Boolean @default(false)
  canManageStock       Boolean @default(false)
  canManageUsers       Boolean @default(false)
  canAssignPermissions Boolean @default(false)
  canSell              Boolean @default(true)
  canViewOrders        Boolean @default(false)
  canViewSensitiveData Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HomepageSettings {
  id Int @id @default(autoincrement())

  announcementEnabled   Boolean @default(true)
  announcementText      String?
  announcementLink      String?
  announcementLinkLabel String?

  heroEyebrow    String @default("Yeni Sezon")
  heroTitle      String
  heroSubtitle   String
  heroButtonText String
  heroButtonLink String

  heroCard1Enabled Boolean @default(true)
  heroCard1Title   String?
  heroCard1Image   String?
  heroCard1Link    String?

  heroCard2Enabled Boolean @default(false)
  heroCard2Title   String?
  heroCard2Image   String?
  heroCard2Link    String?

  featuredCategoriesEnabled Boolean @default(true)
  featuredCategoriesTitle   String  @default("Öne Çıkan Kategoriler")

  featuredProductsEnabled Boolean @default(true)
  featuredProductsTitle   String  @default("Haftanın Ürünleri")

  newProductsEnabled Boolean @default(true)
  newProductsTitle   String  @default("En Yeniler")

  discountedProductsEnabled Boolean @default(true)
  discountedProductsTitle   String  @default("İndirimdekiler")

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
model CustomerUser {
  id        Int    @id @default(autoincrement())
  name      String
  email     String @unique
  passwordHash String?

  phone     String?
  
  orders    Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Order {
  id Int @id @default(autoincrement())

  orderNumber String @unique

  customerId Int?
  customer   CustomerUser? @relation(fields: [customerId], references: [id])

  name    String
  email   String
  phone   String

  city    String
  district String
  address String
  note    String?

  totalPrice Int

  status String @default("PENDING") // PENDING / PAID / SHIPPED / CANCELLED

  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stockRestored Boolean @default(false)
}

model OrderItem {
  id Int @id @default(autoincrement())

  orderId Int
  order   Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId Int
  productName String

  color String?
  size  String?

  price Int
  quantity Int

  createdAt DateTime @default(now())
}